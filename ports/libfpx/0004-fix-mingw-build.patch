diff --git a/oless/h/ref.hxx b/oless/h/ref.hxx
index 982aa24..3f0c82c 100644
--- a/oless/h/ref.hxx
+++ b/oless/h/ref.hxx
@@ -49,6 +49,13 @@ typedef int32_t HRESULT;
 #define STDMETHODCALLTYPE __stdcall
 #define EXPORTDLL _declspec(dllexport)
 
+#elif defined(__MINGW32__)
+/* MinGW provides STDMETHODCALLTYPE via Windows headers; keep STDCALL so that
+ * libfpx's own macros match the system ABI. */
+#define STDCALL __stdcall
+#define EXPORTDLL
+/* Do NOT redefine STDMETHODCALLTYPE - let MinGW keep __stdcall. */
+
 #else // _MSC_VER
 
 #define STDCALL 
