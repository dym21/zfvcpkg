--- a/cmake/onnxruntime_cuda.cmake
+++ b/cmake/onnxruntime_cuda.cmake
@@ -1,5 +1,15 @@
 # Copyright (c) Microsoft Corporation. All rights reserved.
 # Licensed under the MIT License.
 
+# CUDA support fixes for vcpkg
+if(onnxruntime_USE_CUDA)
+  find_package(CUDAToolkit REQUIRED)
+  find_package(cudnn CONFIG REQUIRED)
+  
+  set(CUDA_ARCHITECTURES "70;75;80;86" CACHE STRING "CUDA architectures")
+  set(CMAKE_CUDA_STANDARD 17)
+  set(CMAKE_CUDA_STANDARD_REQUIRED ON)
+endif()
+
 # ONNX Runtime CUDA Execution Provider Configuration
 
 if(onnxruntime_USE_CUDA)
   enable_language(CUDA)
   
   # Find CUDA toolkit
-  find_package(CUDAToolkit REQUIRED)
-  find_package(cudnn CONFIG REQUIRED)
+  if(NOT CUDAToolkit_FOUND)
+    message(FATAL_ERROR "CUDA Toolkit not found. Please install CUDA and set CUDAToolkit_ROOT.")
+  endif()
   
   # Set CUDA architectures
-  set(CUDA_ARCHITECTURES "70;75;80;86" CACHE STRING "CUDA architectures")
+  if(NOT DEFINED CMAKE_CUDA_ARCHITECTURES)
+    set(CMAKE_CUDA_ARCHITECTURES ${CUDA_ARCHITECTURES})
+  endif()
   
   # Enable FP16 for supported architectures
   option(onnxruntime_ENABLE_FP16 "Enable FP16 precision" ON)
   
   # CUDA provider sources
   list(APPEND ONNXRUNTIME_PROVIDER_SOURCES
-    onnxruntime/core/providers/cuda/cuda_execution_provider.cc
-    onnxruntime/core/providers/cuda/cuda_allocator.cc
-    onnxruntime/core/providers/cuda/cuda_common.cc
+    ${CMAKE_CURRENT_SOURCE_DIR}/onnxruntime/core/providers/cuda/cuda_execution_provider.cc
+    ${CMAKE_CURRENT_SOURCE_DIR}/onnxruntime/core/providers/cuda/cuda_allocator.cc
+    ${CMAKE_CURRENT_SOURCE_DIR}/onnxruntime/core/providers/cuda/cuda_common.cc
   )
   
   # Add CUDA include directories
-  include_directories(${CUDAToolkit_INCLUDE_DIRS})
+  include_directories(
+    ${CUDAToolkit_INCLUDE_DIRS}
+    ${cudnn_INCLUDE_DIR}
+  )
   
   # Link CUDA libraries
   list(APPEND ONNXRUNTIME_PROVIDER_LIBS
-    CUDA::cudart
-    cudnn::cudnn
+    CUDA::cudart
+    cudnn::cudnn
+    CUDA::cublas
+    CUDA::cublasLt
+    CUDA::curand
+    CUDA::cufft
   )
   
+  # Set CUDA compiler flags
+  set(CMAKE_CUDA_FLAGS "${CMAKE_CUDA_FLAGS} --expt-relaxed-constexpr")
+  set(CMAKE_CUDA_FLAGS_RELEASE "${CMAKE_CUDA_FLAGS_RELEASE} -O3 -DNDEBUG")
+
+  # Enable tensor cores for Volta and newer
+  if(CMAKE_CUDA_ARCHITECTURES MATCHES "70|75|80|86|87|90")
+    set(CMAKE_CUDA_FLAGS "${CMAKE_CUDA_FLAGS} --use_fast_math")
+  endif()
 endif()
