{
  "name": "onnxruntime",
  "version": "1.20.1",
  "description": "ONNX Runtime is a cross-platform inference and training machine-learning accelerator",
  "homepage": "https://github.com/microsoft/onnxruntime",
  "license": "MIT",
  "supports": "!uwp",
  "dependencies": [
    "protobuf",
    "flatbuffers",
    "abseil",
    "eigen3",
    "re2",
    "nlohmann-json",
    "cpuinfo"
  ],
  "features": {
    "cuda": {
      "description": "Enable CUDA execution provider",
      "dependencies": ["cuda", "cudnn", "cudnn-frontend"]
    },
    "tensorrt": {
      "description": "Enable TensorRT execution provider",
      "dependencies": ["tensorrt", "cuda"]
    },
    "directml": {
      "description": "Enable DirectML execution provider for Windows",
      "supports": "windows",
      "dependencies": ["directx12-agility"]
    },
    "webassembly": {
      "description": "Enable WebAssembly support",
      "dependencies": ["pthreadpool"]
    }
  }
}
