--- a/cmake/onnxruntime.cmake
+++ b/cmake/onnxruntime.cmake
@@ -1,6 +1,10 @@
 # Copyright (c) Microsoft Corporation. All rights reserved.
 # Licensed under the MIT License.
 
+# Fix for vcpkg integration
+set(CMAKE_POSITION_INDEPENDENT_CODE ON)
+set(BUILD_SHARED_LIBS OFF)
+
 # ONNX Runtime CMake configuration
 # This file is included from the top-level CMakeLists.txt
 
 # Disable unnecessary build options
 option(onnxruntime_BUILD_UNIT_TESTS "Build unit tests" OFF)
 option(onnxruntime_BUILD_SHARED_LIBS "Build shared libraries" OFF)
 option(onnxruntime_ENABLE_CPUINFO "Enable cpuinfo" ON)
 option(onnxruntime_USE_FULL_PROTOBUF "Use full protobuf" ON)
 
+# Ensure proper C++ standard
+set(CMAKE_CXX_STANDARD 17 CACHE STRING "C++ standard")
+set(CMAKE_CXX_STANDARD_REQUIRED ON)
+
 # Disable Microsoft-specific internal features for non-Windows builds
 if(NOT WIN32)
   option(onnxruntime_ENABLE_MICROSOFT_INTERNAL "Enable Microsoft internal features" OFF)
 endif()
 
+# Fix include directories for vcpkg
+include_directories(${CMAKE_CURRENT_SOURCE_DIR}/include)
+include_directories(${CMAKE_CURRENT_SOURCE_DIR}/onnxruntime/core/session)
+
 # Set default build type if not specified
 if(NOT CMAKE_BUILD_TYPE AND NOT CMAKE_CONFIGURATION_TYPES)
   message(STATUS "Setting build type to 'Release' as none was specified.")
