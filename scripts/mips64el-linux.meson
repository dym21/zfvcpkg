[binaries]
c = '/opt/zftoolchain/mips64el-zftoolchain-linux-gnu-x86_64/bin/mips64el-zftoolchain-linux-gnu-gcc'
cpp = '/opt/zftoolchain/mips64el-zftoolchain-linux-gnu-x86_64/bin/mips64el-zftoolchain-linux-gnu-g++'
ar = '/opt/zftoolchain/mips64el-zftoolchain-linux-gnu-x86_64/bin/mips64el-zftoolchain-linux-gnu-ar'
strip = '/opt/zftoolchain/mips64el-zftoolchain-linux-gnu-x86_64/bin/mips64el-zftoolchain-linux-gnu-strip'
ranlib = '/opt/zftoolchain/mips64el-zftoolchain-linux-gnu-x86_64/bin/mips64el-zftoolchain-linux-gnu-ranlib'
pkgconfig = 'pkg-config'


[host_machine]
system = 'linux'
cpu_family = 'mips64'
cpu = 'mips64el'
endian = 'little'
